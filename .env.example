# TradingView / Chrome DevTools Protocol
CDP_PORT=9222

# Optional after first successful run.
# The monitor prints TV_TARGET_ID so you can skip the tab picker next time.
# TV_TARGET_ID=

# Screenshot settings
SCREENSHOTS_DIR=./screenshots
SCREENSHOT_MODE=full

# Optional path to tradingview-mcp if you use MCP screenshot fallback mode.
# GitHub: https://github.com/tradesdontlie/tradingview-mcp
# TV_MCP_PATH=/Users/YOUR_USERNAME/.claude/tools/tradingview-mcp
# TV_CLI_PATH=/Users/YOUR_USERNAME/.claude/tools/tradingview-mcp/src/cli/index.js

# TraderNote Parse API
TRADENOTE_URL=https://your-tradernote-domain.com
TRADENOTE_APP_ID=your_parse_app_id
TRADENOTE_MASTER_KEY=your_parse_master_key
TRADENOTE_USER_ID=your_parse_user_object_id

# TraderNote trade defaults
TRADENOTE_ACCOUNT=TradingView Replay
TRADENOTE_TIMEZONE=America/New_York
TRADENOTE_CURRENCY=USD
TRADENOTE_TYPE=stock
